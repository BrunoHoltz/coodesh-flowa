#!/usr/bin/env bash
# Pre-commit hook: runs dotnet format check on staged C# files.
# Exits non-zero to abort the commit if formatting issues are found.

set -euo pipefail

STAGED_CS=$(git diff --cached --name-only --diff-filter=ACMR | grep '\.cs$' || true)

if [ -z "$STAGED_CS" ]; then
    exit 0
fi

echo "Running dotnet format check..."

if ! dotnet format FixOrderBooking.sln --verify-no-changes --no-restore 2>&1; then
    echo ""
    echo "  ERROR: Formatting issues detected. Run 'dotnet format' to fix them, then re-stage."
    echo ""
    exit 1
fi

echo "Format check passed."
exit 0

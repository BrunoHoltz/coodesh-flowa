{
  "Infra": {
    "Docker": {
      // Leave empty to auto-discover from PATH / common install locations.
      "ExePath": "",
      // Leave empty to auto-discover by walking up from the test output directory.
      "ComposeFile": ""
    },
    "Endpoints": {
      "Client": {
        "HTTP": {
          "Host": "localhost",
          "Port": 5100
        },
        "FIX": {
          "Host": "localhost",
          "Port": 5002
        }
      },
      "Server": {
        "HTTP": {
          "Host": "localhost",
          "Port": 5000
        },
        "FIX": {
          "Host": "localhost",
          "Port": 5001
        }
      }
    },
    "Timeouts": {
      // How long to wait for each port to become reachable after 'docker compose up -d'.
      "StartSeconds": 300,
      // How long a single port-probe attempt waits when checking already-running containers.
      "PortProbeSeconds": 1,
      // Extra delay after all ports are up, so FIX sessions have time to establish.
      "FixSessionDelaySeconds": 5
    }
  },
  "LoadTest": {
    "Latency": {
      // Total sequential FIX round-trips to measure. Override via INTEGRATION_Acceptance__Latency__TotalRequests.
      "TotalRequests": 100000,
      // Discarded warm-up requests before measurement starts.
      "WarmupRequests": 1000,
      // Maximum allowed mean end-to-end latency in milliseconds.
      "LimitMs": 1.0
    }
  }
}
